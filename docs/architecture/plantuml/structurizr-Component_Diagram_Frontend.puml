rectangle "OverwatchTeamUp\n<size:16>[Software System]</size>" <<Boundary-T3ZlcndhdGNoVGVhbVVw>> {
  rectangle "Web Application\n<size:16>[Container: TypeScript 6, React 19, Vite 8]</size>" <<Boundary-V2ViIEFwcGxpY2F0aW9u>> {
    rectangle "==Application Shell\n<size:16>[Component: React App component]</size>\n\nOwns top-level login and team composition view state and arranges the main page." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.WebApplication.ApplicationShell
    rectangle "==Hero Browser\n<size:16>[Component: React components: SideBar, SearchBar, List, HeroView]</size>\n\nLoads and filters hero summaries. The detailed hero panel currently displays static prototype data." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.WebApplication.HeroBrowser
    rectangle "==Team Composition UI\n<size:16>[Component: React components: TeamComposition, TeamList]</size>\n\nDisplays role slots and existing team compositions. Selection and save behavior are still under development." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.WebApplication.TeamCompositionUI
    rectangle "==Authentication UI\n<size:16>[Component: React component: UserContractView]</size>\n\nProvides login and registration forms and currently calls authentication endpoints directly." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.WebApplication.AuthenticationUI
    folder "==Prototype Data\n<size:16>[Component: JSON fixtures, generated TypeScript DTOs]</size>\n\nSupplies local hero and team composition data while API integration is incomplete." <<Element-RWxlbWVudCxEYXRh>> as OverwatchTeamUp.WebApplication.PrototypeData
  }

  rectangle "==Backend API\n<size:16>[Container: Python 3.12, Django 6, Django REST Framework]</size>\n\nProvides the REST API, authentication, persistence, and hero synchronization." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI
}

