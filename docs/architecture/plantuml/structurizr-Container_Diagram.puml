@startuml
title <size:24>Container View: OverwatchTeamUp</size>\n<size:24>Runtime containers and external dependencies of OverwatchTeamUp.</size>

set separator none
left to right direction
skinparam ranksep 20
skinparam nodesep 5
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element
  .Element-RWxlbWVudA== {
    BackgroundColor: #ffffff;
    LineColor: #55aa55;
    LineStyle: 0;
    LineThickness: 7;
    RoundCorner: 20;
    FontColor: #55aa55;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Database
  .Element-RWxlbWVudCxEYXRhYmFzZQ== {
    BackgroundColor: #ffffff;
    LineColor: #55aa55;
    LineStyle: 0;
    LineThickness: 7;
    FontColor: #55aa55;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Person
  .Element-RWxlbWVudCxQZXJzb24= {
    BackgroundColor: #ffffff;
    LineColor: #55aa55;
    LineStyle: 0;
    LineThickness: 7;
    FontColor: #55aa55;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 4;
    LineStyle: 20-20;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
    MaximumWidth: 200;
  }
  // OverwatchTeamUp
  .Boundary-T3ZlcndhdGNoVGVhbVVw {
    BackgroundColor: #ffffff;
    LineColor: #55aa55;
