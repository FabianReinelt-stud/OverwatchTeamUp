person "==Overwatch Player\n<size:16>[Person]</size>\n\nBrowses hero statistics and manages personal team compositions." <<Element-RWxlbWVudCxQZXJzb24=>> as OverwatchPlayer
rectangle "==OverFast API\n<size:16>[Software System]</size>\n\nThird-party API providing Overwatch hero details and competitive statistics." <<Element-RWxlbWVudA==>> as OverFastAPI

rectangle "OverwatchTeamUp\n<size:16>[Software System]</size>" <<Boundary-T3ZlcndhdGNoVGVhbVVw>> {
  database "==Database\n<size:16>[Container: PostgreSQL 16]</size>\n\nStores users, heroes, abilities, and user-owned team compositions." <<Element-RWxlbWVudCxEYXRhYmFzZQ==>> as OverwatchTeamUp.Database
  rectangle "==Web Application\n<size:16>[Container: TypeScript 6, React 19, Vite 8]</size>\n\nBrowser-based user interface for browsing heroes and managing team compositions. Currently developed on the frontend branch." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.WebApplication
  rectangle "==Backend API\n<size:16>[Container: Python 3.12, Django 6, Django REST Framework]</size>\n\nProvides the REST API, authentication, persistence, and hero synchronization." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI
}

OverwatchPlayer --> OverwatchTeamUp.WebApplication <<Relationship-UmVsYXRpb25zaGlw>> : "Uses"
OverwatchTeamUp.WebApplication --> OverwatchTeamUp.BackendAPI <<Relationship-UmVsYXRpb25zaGlw>> : "Calls the REST API and sends JWT bearer tokens\n<size:16>[JSON/HTTPS]</size>"
OverwatchTeamUp.BackendAPI --> OverwatchTeamUp.Database <<Relationship-UmVsYXRpb25zaGlw>> : "Reads and writes application data\n<size:16>[Django ORM/SQL]</size>"
OverwatchTeamUp.BackendAPI --> OverFastAPI <<Relationship-UmVsYXRpb25zaGlw>> : "Synchronizes hero details and statistics\n<size:16>[JSON/HTTPS]</size>"

@enduml