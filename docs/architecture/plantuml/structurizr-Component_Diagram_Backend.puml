rectangle "==OverFast API\n<size:16>[Software System]</size>\n\nThird-party API providing Overwatch hero details and competitive statistics." <<Element-RWxlbWVudA==>> as OverFastAPI

rectangle "OverwatchTeamUp\n<size:16>[Software System]</size>" <<Boundary-T3ZlcndhdGNoVGVhbVVw>> {
  rectangle "Backend API\n<size:16>[Container: Python 3.12, Django 6, Django REST Framework]</size>" <<Boundary-QmFja2VuZCBBUEk=>> {
    rectangle "==Authentication API\n<size:16>[Component: Django REST Framework, Simple JWT]</size>\n\nRegisters users, issues JWT access and refresh tokens, and authenticates protected requests." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.AuthenticationAPI
    rectangle "==Hero API Views\n<size:16>[Component: Django REST Framework function-based views]</size>\n\nProvides public endpoints for listing heroes and retrieving hero details." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.HeroAPIViews
    rectangle "==Team Composition API Views\n<size:16>[Component: Django REST Framework function-based views]</size>\n\nProvides authenticated CRUD endpoints scoped to the current user's team compositions." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.TeamCompositionAPIViews
    rectangle "==API Serializers\n<size:16>[Component: Django REST Framework serializers]</size>\n\nValidates request payloads and maps domain entities to API DTOs." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.APISerializers
    rectangle "==Team Composition Service\n<size:16>[Component: Python application service]</size>\n\nCoordinates team composition use cases and enforces creation and update rules through the domain model." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.TeamCompositionService
    rectangle "==Domain Model\n<size:16>[Component: Python dataclasses]</size>\n\nDefines hero and team composition entities, including unique-hero and role-distribution rules." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.DomainModel
    rectangle "==Hero Port\n<size:16>[Component: Python abstract base class]</size>\n\nDefines hero query and persistence operations required by application services." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.HeroPort
    rectangle "==Team Composition Port\n<size:16>[Component: Python abstract base class]</size>\n\nDefines user-scoped team composition persistence operations." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.TeamCompositionPort
    rectangle "==External Hero Source Port\n<size:16>[Component: Python abstract base class]</size>\n\nDefines the external hero data required by synchronization." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.ExternalHeroSourcePort
    rectangle "==Hero Database Adapter\n<size:16>[Component: Python, Django ORM]</size>\n\nImplements the hero persistence port using Django models and maps between database records and domain entities." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.HeroDatabaseAdapter
    rectangle "==Team Composition Database Adapter\n<size:16>[Component: Python, Django ORM]</size>\n\nImplements user-scoped team composition persistence and maps records to domain entities." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.TeamCompositionDatabaseAdapter
    rectangle "==Hero Sync Command\n<size:16>[Component: Django management command]</size>\n\nRuns the hero synchronization during backend startup or via manage.py sync_heroes." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.HeroSyncCommand
    rectangle "==Hero Sync Service\n<size:16>[Component: Python application service]</size>\n\nCoordinates fetching all heroes and upserting them through application ports." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.HeroSyncService
    rectangle "==OverFast API Adapter\n<size:16>[Component: Python, Requests]</size>\n\nImplements the external hero source port and maps OverFast responses to domain entities." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.BackendAPI.OverFastAPIAdapter
  }

  database "==Database\n<size:16>[Container: PostgreSQL 16]</size>\n\nStores users, heroes, abilities, and user-owned team compositions." <<Element-RWxlbWVudCxEYXRhYmFzZQ==>> as OverwatchTeamUp.Database
  rectangle "==Web Application\n<size:16>[Container: TypeScript 6, React 19, Vite 8]</size>\n\nBrowser-based user interface for browsing heroes and managing team compositions. Currently developed on the frontend branch." <<Element-RWxlbWVudA==>> as OverwatchTeamUp.WebApplication
}

